{
  "manifest_version": 2,
  "version": "1.8.0",
  "name": "NAI NewAPI 网关图片生成插件（nai_draw_plugin）",
  "description": "与 nai_pic_plugin 共享同一套业务逻辑（命令、提示词生成、撤回、管理员、检索），底层请求走 NewAPI 兼容 OpenAI 协议（POST /v1/chat/completions）。",
  "author": {
    "name": "久远",
    "url": "https://github.com/Rabbit-Jia-Er"
  },
  "license": "GPL-v3.0-or-later",
  "urls": {
    "repository": "https://github.com/saberlights/nai_draw_plugin",
    "homepage": "https://github.com/saberlights/nai_draw_plugin",
    "documentation": "https://github.com/saberlights/nai_draw_plugin",
    "issues": "https://github.com/saberlights/nai_draw_plugin/issues"
  },
  "host_application": {
    "min_version": "0.10.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "config.get_all",
    "message.get_recent",
    "send.command",
    "send.custom",
    "send.text",
    "network.http"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "saberlights.nai-draw-plugin"
}
